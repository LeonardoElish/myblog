                </mxCell>
                <mxCell id="19" value="&lt;b style=&quot;font-size: 16px;&quot;&gt;🔄 Copy-on-Write Signal-Slot Pattern&lt;/b&gt;&#xa;&lt;span style=&quot;font-size: 13px;&quot;&gt;线程安全的信号槽实现架构 (Muduo-style)&lt;/span&gt;" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;shadow=1;glass=0;" vertex="1" parent="1">
                    <mxGeometry x="80" y="10" width="800" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="&lt;b style=&quot;font-size: 13px;&quot;&gt;🔑 核心设计要点&lt;/b&gt;&#xa;&#xa;• &lt;b&gt;智能指针管理&lt;/b&gt;: Signal 通过 shared_ptr 拥有 SignalImpl&#xa;• &lt;b&gt;写时复制&lt;/b&gt;: SignalImpl 用 shared_ptr 管理 SlotList (COW)&#xa;• &lt;b&gt;避免循环引用&lt;/b&gt;: SlotList 用 weak_ptr 观察 SlotImpl&#xa;• &lt;b&gt;反向引用&lt;/b&gt;: SlotImpl 用 weak_ptr 引用 SignalImpl&#xa;• &lt;b&gt;生命周期绑定&lt;/b&gt;: tie_ 用于对象生命周期管理&#xa;• &lt;b&gt;线程安全&lt;/b&gt;: mutex_ 保护 slots_ 的修改操作" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#333333;shadow=1;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
                    <mxGeometry x="70" y="660" width="380" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="&lt;b style=&quot;font-size: 13px;&quot;&gt;📊 内存布局示意&lt;/b&gt;&#xa;&#xa;Signal::impl_ ──────► SignalImpl&#xa;                        │&#xa;                        ├─ slots_ ───► SlotList&#xa;                        │                │&#xa;                        │                ├─ weak_ptr&lt;Slot1&gt;&#xa;                        │                ├─ weak_ptr&lt;Slot2&gt;&#xa;                        │                └─ weak_ptr&lt;Slot3&gt;&#xa;                        │&#xa;                        └─ mutex_" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#333333;shadow=1;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
                    <mxGeometry x="500" y="630" width="380" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="25" value="&lt;div style=&quot;color: rgb(187, 187, 187); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;span&gt;&lt;span style=&quot;color: rgb(187, 187, 187);&quot;&gt;vector&lt;/span&gt;&lt;span style=&quot;color: rgb(224, 108, 117);&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: rgb(187, 187, 187);&quot;&gt;std&lt;/span&gt;&lt;span style=&quot;color: rgb(171, 178, 191);&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: rgb(187, 187, 187);&quot;&gt;weak_ptr&lt;/span&gt;&lt;span style=&quot;color: rgb(224, 108, 117);&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: rgb(187, 187, 187);&quot;&gt;SlotImpl&lt;/span&gt;&lt;span style=&quot;color: rgb(224, 108, 117);&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: rgb(187, 187, 187);&quot;&gt;Callback&lt;/span&gt;&lt;span style=&quot;color: rgb(224, 108, 117);&quot;&gt;&amp;gt;&amp;gt;&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(187, 187, 187);&quot;&gt; &lt;/span&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fad9d5;strokeColor=#ae4132;fontSize=10;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
                    <mxGeometry x="950" y="350" width="340" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="26" value="&lt;b&gt;📝 调用流程&lt;/b&gt;&#xa;&#xa;1. signal.call(args...)&#xa;2. 获取 slots_ 副本 (无锁读取)&#xa;3. 遍历 SlotList&#xa;4. 对每个 weak_ptr 调用 lock()&#xa;5. 如果成功，检查 tied_&#xa;6. 如果绑定对象存在，调用 callback_&#xa;7. 继续下一个槽" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#000000;shadow=1;spacingLeft=10;spacingTop=5;fontFamily=Consolas;" vertex="1" parent="1">
                    <mxGeometry x="80" y="270" width="340" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="27" value="&lt;b&gt;🔒 线程安全机制&lt;/b&gt;&#xa;&#xa;&lt;b&gt;写操作 (connect/disconnect):&lt;/b&gt;&#xa;• MutexLockGuard 加锁&#xa;• copyOnWrite() 确保独占&#xa;• 修改新副本&#xa;• 原子替换 slots_ 指针&#xa;&#xa;&lt;b&gt;读操作 (call):&lt;/b&gt;&#xa;• 快速复制 shared_ptr&#xa;• 无需加锁&#xa;• 遍历旧副本" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#000000;shadow=1;spacingLeft=10;spacingTop=5;fontFamily=Consolas;" vertex="1" parent="1">
                    <mxGeometry x="80" y="460" width="340" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="28" value="⚠️ 避免循环引用" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;position2=0.5;base=20;size=20;" vertex="1" parent="1">
                    <mxGeometry x="440" y="360" width="140" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="meO-5Bj2SNIODsf30AGX-30" style="edgeStyle=none;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="25" target="10">
