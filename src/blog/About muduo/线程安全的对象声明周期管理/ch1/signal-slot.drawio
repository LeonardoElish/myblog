                <mxCell id="30" value="💡 懒清理策略" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;position2=0.2;base=20;size=20;" vertex="1" parent="1">
