                <mxCell id="14" value="+ ~SlotImpl()&#xa;  // 析构时调用 data_.lock()&#xa;  // 如果 SignalImpl 存在则 clean()" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;fontFamily=Consolas;" parent="11" vertex="1">
