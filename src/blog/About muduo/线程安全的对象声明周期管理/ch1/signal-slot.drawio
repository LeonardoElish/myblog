                <mxCell id="18" value="references (weak_ptr)" style="endArrow=open;endSize=12;dashed=1;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#82b366;dashPattern=8 8;fontSize=12;fontStyle=1;" parent="1" source="30" target="6" edge="1">
